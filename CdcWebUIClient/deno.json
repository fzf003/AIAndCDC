{
  "name": "@aiandcdc/web-ui-client",
  "version": "1.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite --logLevel warn",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview"
  },
  "imports": {
    "vue": "npm:vue@^3.4.0",
    "naive-ui": "npm:naive-ui@^2.38.0",
    "@vicons/ionicons5": "npm:@vicons/ionicons5@^0.12.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "vue"
  }
}
